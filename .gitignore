# Dependencies
node_modules/
# NOTE: package-lock.json is intentionally committed. The lockfile pins exact
# dependency versions so every machine, CI, and the deploy hosts install the
# same tree. Never ignore it.

# Expo / Metro build caches (regenerated automatically, never commit)
.expo/

# Environment variables (CRITICAL - never commit secrets)
.env
.env.local
.env.*.local

# Database
data/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
.claude/
*.swp
*.swo

# Logs
logs/
*.log
npm-debug.log*

# Testing
coverage/
.nyc_output/

# Destructive dev scripts, never commit these
wipe-all-users.js
delete-user.js
reset-user.js
reset-username.js
